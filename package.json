{
  "name": "stumbl",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "EXPO_NO_WIDGETS=1 expo start",
    "start:native": "expo start",
    "sync:icons": "bash scripts/sync-ios-icons.sh",
    "ios": "npm run sync:icons && expo run:ios",
    "prebuild": "expo prebuild --platform ios && npm run sync:icons",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "android": "expo run:android"
  },
  "dependencies": {
    "@expo/ui": "~55.0.17",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~55.0.25",
    "expo-asset": "~55.0.17",
    "expo-constants": "~55.0.16",
    "expo-file-system": "~55.0.21",
    "expo-font": "~55.0.8",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.15",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-widgets": "55.0.8",
    "nativewind": "latest",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.4",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.2.10",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~55.0.1",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.2"
  }
}
